# Copy to .env and fill in your real values. Never commit .env.

DISCORD_BOT_TOKEN=

# --- Global SSH defaults ---
# Used by any sietch below that doesn't override them. If every sietch
# below sets its own SIETCH_N_SSH_* vars (e.g. because they're on
# different hosts), these can be left blank.
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=/keys/dune_status_key

KUBECTL_PATH=/usr/local/bin/kubectl
# Use the FULL path (e.g. /home/youruser/.kube/config), not "~" - shell
# quoting inside the bot's SSH command prevents tilde expansion.
KUBECONFIG_PATH=

POLL_INTERVAL_SECONDS=60
# PLAYER_LOG_TAIL_LINES=500

# --- Sietches (battlegroups) ---
# One battlegroup per numbered block, starting at 1. See README.md
# "Finding your namespace and battlegroup name" for how to get these two
# values. Add as many SIETCH_N_* blocks as you have servers.
#
# SIETCH_1_NAMESPACE=funcom-seabass-sh-90e2edcd77729fd-jowxys
# SIETCH_1_BATTLEGROUP_NAME=sh-90e2edcd77729fd-jowxys
# SIETCH_1_CHANNEL_ID=123456789012345678
# Uncomment these three only if this sietch is on a DIFFERENT host than
# the global SSH_HOST/USER/KEY_PATH above:
# SIETCH_1_SSH_HOST=
# SIETCH_1_SSH_USER=
# SIETCH_1_SSH_KEY_PATH=
#
# SIETCH_2_NAMESPACE=funcom-seabass-sh-anothersuffix
# SIETCH_2_BATTLEGROUP_NAME=sh-anothersuffix
# SIETCH_2_CHANNEL_ID=987654321098765432

# --- OR: legacy single-sietch config ---
# If you deployed this bot before multi-sietch support existed, these
# three still work exactly as before - no changes needed. Leave the
# SIETCH_N_* block above entirely commented out if you're using this.
# K8S_NAMESPACE=
# BATTLEGROUP_NAME=
# DISCORD_CHANNEL_ID=
