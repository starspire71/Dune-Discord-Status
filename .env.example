# Copy to .env and fill in your real values. Never commit .env.

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# IP/hostname of your Dune Awakening VM, reachable via SSH from wherever
# this bot runs
SSH_HOST=
SSH_USER=
# Path INSIDE the container to the mounted private key - see the
# `docker run` command in README.md, which mounts your real key here.
SSH_KEY_PATH=/keys/dune_status_key

# See README.md "Finding your namespace and battlegroup name" for how to
# get these two values for YOUR server - they're unique per installation.
K8S_NAMESPACE=
BATTLEGROUP_NAME=

KUBECTL_PATH=/usr/local/bin/kubectl
# Use the FULL path (e.g. /home/youruser/.kube/config), not "~" - shell
# quoting inside the bot's SSH command prevents tilde expansion. See
# README.md troubleshooting if you're not sure of yours.
KUBECONFIG_PATH=

POLL_INTERVAL_SECONDS=60

# Optional - how many recent log lines per map pod to scan for player
# names. Higher = better chance of catching a name, but slower per poll.
# PLAYER_LOG_TAIL_LINES=500
